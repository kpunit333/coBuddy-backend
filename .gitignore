# --- DEPENDENCIES ---
# Block the heavy node_modules folder
node_modules/
jspm_packages/

# --- SECURITY & SECRETS ---
# Crucial: Never commit your MongoDB URI or session secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- COMPILED OUTPUT ---
# Exclude the 'dist' or 'build' folders generated by the TS compiler
dist/
build/
out/

# --- LOGS ---
# Keep logs local to your environment
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# --- IDE & OS SPECIFIC ---
# Personal IDE settings that shouldn't affect other operators
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- TEST COVERAGE ---
coverage/
.nyc_output/

# --- BACKEND SPECIFIC ---
# If you use local SQLite for testing data engineering tasks
*.db
*.sqlite